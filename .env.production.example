# PostgreSQL (для docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=event_crm

# Backend (приложение читает эти переменные)
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=false
DATABASE_URL=postgresql+asyncpg://postgres:secure_password_here@db:5432/event_crm
REDIS_URL=redis://redis:6379/0

# Telegram Bot (для напоминаний в задачах)
TELEGRAM_BOT_TOKEN=

# Telethon (сбор заявок из чата, QR-авторизация)
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=

# OpenAI (опционально, для AI-фильтрации сообщений в Telethon)
OPENAI_API_KEY=
